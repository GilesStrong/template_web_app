# Postgres
POSTGRES_DB=tests_myapp
POSTGRES_USER=tests_myapp_user
POSTGRES_PASSWORD=tests_myapp_password
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Redis
REDIS_URL=redis://redis:6379/0

# Django
SECRET_KEY='django-insecure'
ALLOWED_HOSTS=["localhost","127.0.0.1", "web", "0.0.0.0"]
CSRF_TRUSTED_ORIGINS=[]

# Environment
ENVIRONMENT=development
DEBUG=True
LOCALITY="Asia/Tokyo"
PUBLIC_URL=""

# Celery
CELERY_TASK_DEFAULT_QUEUE=default
CELERY_TASK_DEFAULT_EXCHANGE=default
CELERY_TASK_DEFAULT_ROUTING_KEY=default
CELERY_TASK_CREATE_MISSING_QUEUES=False
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# qdrant
QDRANT_URL = "http://qdrant:6333"
HNSW_M = 16
HNSW_EF_CONSTRUCT = 128
HNSW_EF_SEARCH = 128

# Logfire
LOGFIRE_TOKEN=''
LOGFIRE_ENVIRONMENT=''

# Google Auth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_ENFORCE_ALLOWED_EMAILS="false"
GOOGLE_ALLOWED_EMAILS=[]

# BE Auth
JWT_ISSUER=""
JWT_AUDIENCE=""
JWT_SIGNING_KEY=""
ACCESS_TOKEN_TTL_SECONDS=3600
REFRESH_TOKEN_TTL_SECONDS=2592000
AUTH_RATE_LIMIT_FAIL_OPEN=False
AUTH_RATE_LIMIT_TRUSTED_PROXY_CIDRS=[]
ADMIN_ALLOWLIST_CIDRS=127.0.0.1/32

# Caddy
PORT=3000
