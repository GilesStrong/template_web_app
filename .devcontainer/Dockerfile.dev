FROM python:3.12-slim

ARG UID=1000
ARG GID=1000

# Create a non-root user matching host UID/GID
RUN groupadd -g ${GID} dev && useradd -m -u ${UID} -g ${GID} -s /bin/bash dev

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 
#     PIP_DISABLE_PIP_VERSION_CHECK=1 \
#     UV_PROJECT_ENVIRONMENT=/workspace/.venv \
#     PATH="/workspace/.venv/bin:$PATH"

# WORKDIR /workspace

# Basic OS deps (dev tooling + Playwright runtime libraries for frontend E2E)
RUN apt-get update && apt-get install -y --no-install-recommends \
    git curl ca-certificates build-essential openssh-client iproute2 postgresql-client npm unzip \
    libglib2.0-0 libnss3 libnspr4 libdbus-1-3 \
    libatk1.0-0 libatk-bridge2.0-0 libcups2 libdrm2 libxkbcommon0 libatspi2.0-0 \
    libxcomposite1 libxdamage1 libxfixes3 libxrandr2 libgbm1 libasound2 \
    libpango-1.0-0 libcairo2 libx11-6 libxcb1 libxext6 libxrender1 libxcursor1 libxi6 libxtst6 \
    libfontconfig1 fonts-liberation wget xdg-utils \
    && rm -rf /var/lib/apt/lists/*

